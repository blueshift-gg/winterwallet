{
  "name": "@blueshift-gg/winterwallet",
  "version": "0.1.0",
  "description": "TypeScript SDK for building WinterWallet Solana instructions and Advance plans.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/blueshift-gg/winterwallet/tree/master/sdk/ts#readme",
  "bugs": {
    "url": "https://github.com/blueshift-gg/winterwallet/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blueshift-gg/winterwallet.git",
    "directory": "sdk/ts"
  },
  "keywords": [
    "solana",
    "winterwallet",
    "winternitz",
    "wallet",
    "post-quantum",
    "one-time-signature"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build:js": "bun build src/index.ts --outdir dist --format esm --target node --external '@solana/codecs' --external '@solana/web3.js' --sourcemap=external",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "bun run clean && bun run build:js && bun run build:types",
    "typecheck": "tsc",
    "test": "vitest run",
    "lint:publint": "publint",
    "lint:attw": "attw --pack . --profile esm-only",
    "lint": "bun run lint:publint && bun run lint:attw",
    "prepublishOnly": "bun run build && bun run test && bun run lint"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@solana/codecs": "^6.8.0",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "publint": "^0.3.0",
    "typescript": "^5.4.0",
    "vitest": "^3.1.0"
  }
}
