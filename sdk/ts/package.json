{
  "name": "@winterwallet/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for building WinterWallet Solana instructions and Advance plans.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/winterwallet/winterwallet.git",
    "directory": "sdk/ts"
  },
  "keywords": [
    "solana",
    "winterwallet",
    "winternitz",
    "wallet"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "@noble/hashes": "^1.7.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^3.1.0"
  }
}
